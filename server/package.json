{
  "name": "craftlocal-server",
  "version": "1.0.0",
  "description": "CraftLocal - Cultural & Craft Workshop Booking System Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "ts-node-dev --transpile-only src/seeders/seed.ts",
    "upload:cloudinary": "ts-node src/scripts/uploadImagesToCloudinary.ts",
    "images:update-db": "ts-node src/scripts/updateDatabaseImages.ts",
    "cloudinary:test": "ts-node src/scripts/testCloudinaryUpload.ts",
    "tickets:backfill-code": "ts-node src/scripts/backfillTicketCheckInCode.ts",
    "tickets:repair-paid": "ts-node src/scripts/repairPaidBookingsTickets.ts",
    "statuses:normalize": "ts-node src/scripts/normalizeStatuses.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@payos/node": "^2.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.16",
    "@types/qrcode": "^1.5.5",
    "@types/streamifier": "^0.1.2",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.1",
    "google-auth-library": "^10.7.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.6.0",
    "nodemailer": "^6.9.15",
    "openai": "^6.45.0",
    "qrcode": "^1.5.4",
    "streamifier": "^0.1.1",
    "typescript": "5.8.3",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0"
  }
}

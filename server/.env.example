PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/craftlocal?retryWrites=true&w=majority
JWT_SECRET=craftlocal_jwt_secret_key_2024_very_secure
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:5000

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# payOS Payment Gateway
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
PAYOS_RETURN_URL=http://localhost:5173/payment/payos-return
PAYOS_CANCEL_URL=http://localhost:5173/payment/payos-cancel

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
AI_FREE_TIER_MODE=true
AI_MAX_WORKSHOPS_CONTEXT=12
AI_CACHE_TTL_SECONDS=300
